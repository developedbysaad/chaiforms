# Kamal secrets — committed by design.
#
# This file contains ONLY `$VAR` indirections (no literal secret values), so it
# is safe to commit. The deploy workflow sets the real values from GitHub
# Environment secrets and exports them as env vars before `kamal deploy`; Kamal
# loads this file with dotenv and resolves the references.
#
# Rules of thumb (see docs/DEPLOYMENT.md → "Secrets & Kamal masking"):
#   • Only TRUE secrets belong here + in `env.secret`. Public/build-time values
#     (NEXT_PUBLIC_*) are passed as `builder.args` in config/deploy.yml, NOT here
#     — Kamal masks secret values in its logs, so marking a public value secret
#     is pointless and risks redacting that same string elsewhere in the output.
#   • Optional integration secrets use `${VAR:-}` so an UNSET one resolves to an
#     empty string instead of failing the deploy (the app treats empty = absent).

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Database — composed from the Postgres accessory creds so the app and accessory
# never drift. NOTE: POSTGRES_PASSWORD is interpolated into a URL, so it MUST be
# URL-safe — avoid @ : / # ? % and spaces. Generate a safe one with:
#   openssl rand -hex 32   (hex is all [0-9a-f], always URL-safe)
DATABASE_URL=postgres://${POSTGRES_USER:-chaiforms}:$POSTGRES_PASSWORD@chaiforms-db:5432/${POSTGRES_DB:-chaiforms_production}
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

BETTER_AUTH_SECRET=$BETTER_AUTH_SECRET

UPSTASH_REDIS_REST_URL=$UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=$UPSTASH_REDIS_REST_TOKEN

RESEND_API_KEY=$RESEND_API_KEY

# Google Sheets integration (optional — empty when unset disables the feature).
GOOGLE_OAUTH_CLIENT_ID=${GOOGLE_OAUTH_CLIENT_ID:-}
GOOGLE_OAUTH_CLIENT_SECRET=${GOOGLE_OAUTH_CLIENT_SECRET:-}

# Cloudflare R2 file uploads (optional — all empty when unset disables uploads).
R2_ACCOUNT_ID=${R2_ACCOUNT_ID:-}
R2_ACCESS_KEY_ID=${R2_ACCESS_KEY_ID:-}
R2_SECRET_ACCESS_KEY=${R2_SECRET_ACCESS_KEY:-}
R2_BUCKET=${R2_BUCKET:-}
R2_PUBLIC_BASE_URL=${R2_PUBLIC_BASE_URL:-}
