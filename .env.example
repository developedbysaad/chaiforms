# =============================================================================
# ChaiForm — environment template
# -----------------------------------------------------------------------------
# Two apps in the Turborepo:
#   • apps/api  — Express + tRPC + Scalar, runs on :8000
#   • apps/web  — Next.js, runs on :3000 and reverse-proxies API paths to apps/api
# Copy this file to .env at the repo root, then run ./setup.sh to symlink it into
# each app/package (or copy it manually). The values are shared.
#
# Only DATABASE_URL, BETTER_AUTH_SECRET and BETTER_AUTH_URL are strictly
# required. Everything else has a safe default or degrades gracefully (noted).
# =============================================================================

# ---- Core -------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# Where the web app reaches the api (server-to-server + Next reverse-proxy).
#   • Local + prod (single container): http://localhost:8000
API_INTERNAL_URL=http://localhost:8000

# Postgres connection string.
#  • Local: the docker one-liner in the README runs Postgres on host port 5434.
#      postgres://chaiforms:chaiforms_local@localhost:5434/chaiforms_dev
#  • Neon (prod option): console.neon.tech → project → Connect → "pooled".
#      A *.neon.tech host auto-selects the serverless HTTP driver.
DATABASE_URL=postgres://chaiforms:chaiforms_local@localhost:5434/chaiforms_dev

# Better Auth signing secret. 32+ chars. Also the master key for the AES-GCM
# encryption of stored captcha secrets and the SHA-256 IP-hash salt — so
# rotating it logs everyone out, invalidates IP hashes, and makes stored
# captcha secrets unreadable (owners must re-enter). Generate:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# The app's own public origin (single-origin → same host that serves pages).
# Cookies and email links are built from this.
#   • Local: http://localhost:3000
#   • Prod:  https://chaiforms.developedbysaad.com
BETTER_AUTH_URL=http://localhost:3000

# Used by the API for absolute URLs (OpenAPI server, verification links, the
# Google OAuth redirect URI, and notification-email links). Keep equal to
# BETTER_AUTH_URL.
PUBLIC_APP_URL=http://localhost:3000

# Origin the API allows for CORS in NON-production only (dev convenience). In
# production CORS for /trpc + /api/auth is skipped entirely (single-origin
# deploy), so this is ignored there. Defaults to http://localhost:3000.
WEB_ORIGIN=http://localhost:3000

# Optional log verbosity for @repo/logger. One of: error | info | debug.
# Unset → the logger picks a sensible default per NODE_ENV.
# LOGGER_LEVEL=info

# ---- Rate limiting (optional) ----------------------------------------------
# Upstash Redis REST. Get from console.upstash.com → create Redis DB → REST.
# If UNSET: the limiter degrades to a permissive no-op (logs a warning in dev,
# an error in prod) — the site stays up, but submission/auth rate limits are off.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Email (optional) -------------------------------------------------------
# Resend API key from resend.com → API Keys. Verify the sending domain there so
# the From address passes SPF/DKIM. If RESEND_API_KEY is UNSET, sendEmail() is a
# no-op (endpoint submissions are stored + shown in dashboard, just not emailed).
RESEND_API_KEY=
RESEND_FROM=ChaiForm <noreply@developedbysaad.com>

# ---- Integrations (optional) ------------------------------------------------
# Response integrations forward each new submission to external tools. They are
# admin-gated (toggle in Dashboard → Admin → Integrations) AND configured
# per-form by the form owner. Delivery is fire-and-forget — it never blocks or
# breaks a submission.
#
#   • Discord: no env needed — the webhook URL is set per-form in the builder.
#   • Google Sheets: requires a Google Cloud OAuth client (Web application).
#       1. console.cloud.google.com → APIs & Services → Credentials → Create
#          OAuth client ID (Web application).
#       2. Add the authorized redirect URI:
#            ${PUBLIC_APP_URL}/api/integrations/google/callback
#          (e.g. http://localhost:3000/api/integrations/google/callback)
#       3. Enable the "Google Sheets API" for the project.
#     If UNSET: the Sheets integration is "unavailable" — admins see a
#     "Configure …" hint instead of a toggle, and form owners never see it.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- AI form generation (NO env var) ----------------------------------------
# AI generation is BYO-key, per-user: each user pastes their own Anthropic API
# key in Dashboard → Settings, validated with a live auth probe then stored
# AES-GCM-encrypted (users.ai_api_key_enc). There is NO server-wide AI env var.
# With no key saved, the builder hides the AI panel and ai.generateForm throws
# PRECONDITION_FAILED only if called. Nothing to configure here.

# ---- Captcha verify endpoints (have sane defaults; rarely change) -----------
# The provider SECRET keys are entered per-endpoint-form in the dashboard and
# stored AES-GCM-encrypted — they are NOT env vars. These only override the
# verification URLs (e.g. for a self-hosted/enterprise captcha).
HCAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# ---- File uploads via Cloudflare R2 (optional) ------------------------------
# Backs the "File upload" field type with presigned uploads to an R2 bucket
# (S3-compatible). ALL of these are OPTIONAL: if ANY is unset, the file_upload
# field is unavailable (the builder disables it with "Configure R2 storage to
# enable file uploads") and uploads.presign returns PRECONDITION_FAILED. Forms
# without file fields are completely unaffected.
#
# From the Cloudflare dashboard → R2:
#   • R2_ACCOUNT_ID         — your Cloudflare account id (the R2 S3 endpoint is
#                             https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
#   • R2_ACCESS_KEY_ID      — R2 API token access key id
#   • R2_SECRET_ACCESS_KEY  — R2 API token secret access key
#   • R2_BUCKET             — bucket name to store uploads in
#   • R2_PUBLIC_BASE_URL    — public read base URL for the bucket (e.g. an R2.dev
#                             URL or a custom domain) used for download links.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ---- Web app (NEXT_PUBLIC_*; baked into the client bundle) -------------------
# Never put secrets here — anything NEXT_PUBLIC_* ships to the browser.
# NOTE: the app's public origin is read SERVER-side from PUBLIC_APP_URL /
# BETTER_AUTH_URL (above) — there is no NEXT_PUBLIC_APP_URL; the browser talks
# to the API same-origin via the Next reverse-proxy.

# Where the BROWSER sends tRPC calls.
#   • Local dev: point straight at the api → http://localhost:8000/trpc
#   • Production: leave UNSET — the browser calls same-origin /trpc and the web
#     app reverse-proxies it to the api (single origin, no CORS).
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Razorpay Payment Link for donations (a static link — no key/secret needed).
# Create one in the Razorpay dashboard → Payment Links, paste the URL.
NEXT_PUBLIC_RAZORPAY_DONATE_LINK=https://rzp.io/l/your-link-here

# Contextual "buy me a chai" donation nudges (dashboard footer + toasts after
# publish/export). Nothing is gated — it's a thank-you-ware ask. Set "true" only
# on the hosted instance so self-hosters never see *our* donate link. Off by default.
NEXT_PUBLIC_ENABLE_CHAI_NUDGE=false

# Social links shown on /open-source.
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername/chaiforms
NEXT_PUBLIC_TWITTER_URL=https://x.com/yourhandle
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourprofile
